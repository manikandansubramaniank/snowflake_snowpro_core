              {
                "id": 378,
                "question": "What file formats does Snowflake support for loading semi-structured data? (Choose three.)\n",
                "choices": {
                  "A": "TSV",
                  "B": "JSON",
                  "C": "PDF",
                  "D": "Avro",
                  "E": "Parquet",
