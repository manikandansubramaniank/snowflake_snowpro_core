              {
                "id": 1162,
                "question": "What should an account administrator do to help a user log into Snowflake, if the user cannot authenticate using\nMulti-Factor Authentication (MFA)?\n",
                "choices": {
                  "A": "Set DISABLE_MFA to TRUE for the user.",
                  "B": "Set MINS_TO_BYPASS_MFA equal to 0 for the user.",
